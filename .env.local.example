# ─── Firebase Client SDK (safe to expose in browser, prefixed with NEXT_PUBLIC_) ───
# Found at: Firebase Console → Project Settings → General → Your apps → Firebase SDK snippet → Config

NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abc123"

# ─── Firebase Admin SDK (server-only, NEVER expose to browser) ─────────────────
# Found at: Firebase Console → Project Settings → Service Accounts → Generate new private key (JSON)
# Then copy the values from the downloaded JSON file:

FIREBASE_PROJECT_ID="your-project-id"              # JSON field: project_id
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"  # JSON field: client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"  # JSON field: private_key (keep \n literals)

# ─── App URL (used for sitemap and redirects) ──────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin user setup ─────────────────────────────────────────────────────────
# UID of the admin Firebase Auth user — set this AFTER creating the user in Firebase Console
# → Authentication → Users → copy the UID column value
# Only needed when running: node scripts/setup-admin.mjs
ADMIN_UID="your-admin-user-uid"
